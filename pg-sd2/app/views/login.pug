extends layout

block content
    style.
        .auth-card {
            border-radius: 24px;
            border: none;
            background: #ffffff;
        }
        .form-control {
            border: 1px solid #e2e8f0;
            padding: 12px 16px;
            border-radius: 12px;
            background-color: #f8fafc;
        }
        .form-control:focus {
            background-color: #ffffff;
            border-color: #0f172a;
            box-shadow: 0 0 0 4px rgba(15, 23, 42, 0.05);
        }
        .auth-bg {
            background: radial-gradient(circle at top right, #f8fafc, #f1f5f9);
            min-height: 85vh;
        }

    .auth-bg.d-flex.justify-content-center.align-items-center
        .container
            .row.justify-content-center
                .col-12(style="max-width: 420px;")
                    .card.auth-card.shadow-lg.p-4.p-md-5
                        .text-center.mb-4
                            .display-6.mb-2 🔄
                            h3.fw-bold Welcome Back
                            p.text-muted.small Log in to your ShareLoop account

                        if error
                            .alert.alert-danger.py-2.small.border-0.rounded-3 #{error}
                        if success
                            .alert.alert-success.py-2.small.border-0.rounded-3 #{success}

                        form(action="/login" method="POST")
                            .mb-3
                                label.form-label.fw-semibold.small(for="email") Email Address
                                input.form-control(
                                    type="email" 
                                    name="email" 
                                    value=email || "" 
                                    placeholder="name@example.com"
                                    required
                                )

                            .mb-4
                                .d-flex.justify-content-between
                                    label.form-label.fw-semibold.small(for="password") Password
                                    //- a.text-decoration-none.small(href="#") Forgot?
                                input.form-control(
                                    type="password" 
                                    name="password" 
                                    placeholder="••••••••"
                                    required
                                )

                            button.btn.btn-dark.btn-lg.w-100.rounded-pill.fw-bold.mb-3(type="submit") Login

                        .text-center
                            p.text-muted.small.mb-0
                                | New to the community? 
                                a.text-dark.fw-bold.text-decoration-none(href="/register") Create an account






