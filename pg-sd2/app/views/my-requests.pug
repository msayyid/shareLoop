extends layout

block content
    .container.mt-4

        h3.mb-4 My Requests

        if requests.length === 0
            .alert.alert-light.border
                p.mb-0 You haven’t made any requests yet.

        else
            .row.g-4

                each request in requests
                    .col-md-6.col-lg-4
                        .card.h-100.shadow-sm.border-0

                            .card-body.d-flex.flex-column

                                // ===== TITLE =====
                                h6.card-title.mb-2
                                    | You requested:
                                    br
                                    span.fw-bold "#{request.title}"

                                // ===== STATUS =====
                                .mb-3
                                    if request.status === 'pending'
                                        span.badge.bg-warning.text-dark Pending
                                    else if request.status === 'accepted'
                                        span.badge.bg-success Accepted
                                    else if request.status === 'declined'
                                        span.badge.bg-danger Declined
                                    else if request.status === 'cancelled'
                                        span.badge.bg-secondary Cancelled
                                    else if request.status === 'completed'
                                        span.badge.bg-primary Completed

                                // ===== ACTIONS =====
                                .mt-auto.d-flex.flex-column.gap-2

                                    // VIEW
                                    a.btn.btn-outline-dark.btn-sm.w-100(
                                        href=`/listing-detail/${request.listing_id}`
                                    ) View Listing

                                    // MESSAGE
                                    if request.status !== 'declined' && request.status !== 'cancelled'
                                        a.btn.btn-outline-primary.btn-sm.w-100(
                                            href=`/requests/${request.request_id}/messages`
                                        ) Message

                                    // CANCEL
                                    if request.status === 'pending'
                                        form(
                                            action=`/requests/${request.request_id}/cancel`
                                            method="POST"
                                            onsubmit="return confirm('Cancel this request?');"
                                        )
                                            button.btn.btn-outline-danger.btn-sm.w-100(type="submit") Cancel Request

                                    // RATE
                                    if request.status === 'completed' && !request.hasRated
                                        a.btn.btn-dark.btn-sm.w-100(
                                            href=`/requests/${request.request_id}/rate`
                                        ) Rate Experience