extends layout

block content
    style.
        .listing-card {
            border-radius: 20px;
            transition: all 0.3s ease;
            overflow: hidden;
            border: 1px solid #f1f5f9 !important;
        }
        .listing-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }
        .img-container {
            position: relative;
            height: 240px;
            overflow: hidden;
        }
        .listing-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .listing-card:hover .listing-img {
            transform: scale(1.05);
        }
        .exchange-badge {
            position: absolute;
            bottom: 12px;
            left: 12px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(4px);
            padding: 5px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            color: #0f172a;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        .availability-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }

    .container.mt-5.mb-5
        //- ===== HEADER =====
        if listings.length > 0
            .d-flex.justify-content-between.align-items-center.mb-5.flex-wrap.gap-3
                div
                    nav(aria-label="breadcrumb")
                        ol.breadcrumb.mb-2
                            li.breadcrumb-item.small: a.text-muted(href="/all-categories") Categories
                            li.breadcrumb-item.small.active(aria-current="page") #{listings[0].category_name}
                    h1.fw-bold.mb-0 #{listings[0].category_name}
                    p.text-muted Browse items shared by your neighbors
                //- a.btn.btn-outline-dark.rounded-pill.px-4.btn-sm(href="/all-categories") 
                //-     i.bi.bi-arrow-left.me-2
                //-     | All Categories
        else
            .text-center.py-5
                .display-1.mb-4 🔍
                h2.fw-bold No listings found
                p.text-muted.mx-auto(style="max-width: 400px;") 
                    | It looks like this category is empty for now. Why not be the first to share something?
                .mt-4.d-flex.justify-content-center.gap-2
                    a.btn.btn-dark.rounded-pill.px-4(href="/listings/new") + Post Listing
                    a.btn.btn-light.rounded-pill.px-4(href="/all-categories") Back to Categories

        //- ===== LISTINGS GRID =====
        if listings.length > 0
            .row.g-4
                each listing in listings
                    .col-md-6.col-lg-4
                        .card.listing-card.h-100.shadow-sm
                            .img-container
                                img.listing-img(
                                    src=listing.image_path || '/images/default-item.png'
                                    alt=listing.title
                                )
                                .exchange-badge 
                                    i.bi.bi-arrow-left-right.me-1
                                    | #{listing.exchange_type}
                                
                                if !listing.is_available
                                    .position-absolute.top-0.end-0.m-2
                                        span.badge.bg-danger.rounded-pill.px-3 In Use

                            .card-body.d-flex.flex-column.p-4
                                .d-flex.justify-content-between.align-items-start.mb-2
                                    h5.fw-bold.mb-0.text-truncate(style="max-width: 80%;") #{listing.title}
                                    if listing.is_available
                                        span.text-success.small.fw-bold
                                            span.availability-dot.bg-success
                                            | Active
                                
                                p.text-muted.small.mb-4.text-truncate-2
                                    | #{listing.description || "No description provided."}

                                .mt-auto
                                    .d-flex.justify-content-between.align-items-center.mb-3
                                        span.text-muted.small
                                            i.bi.bi-shield-check.me-1
                                            | #{listing.condition_status}
                                        //- Optional: Price or Points if you have them
                                    
                                    a.btn.btn-dark.w-100.rounded-pill.fw-bold(href=`/listing-detail/${listing.listing_id}`) 
                                        | View Details










