extends layout

block content
    if listings.length > 0
        .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-2
            div
                h1.mb-1 Listings for Category "#{listings[0].category_name}"
                p.text-muted.mb-0 Browse items in this category
    else
        .mb-4
            h1.mb-1 No listings found
            p.text-muted.mb-0 There are currently no listings in this category.

    if listings.length > 0
        .row.g-4
            each listing in listings
                .col-md-6.col-lg-4
                    .card.h-100.shadow-sm.border-0
                        img.card-img-top(
                            src="https://via.placeholder.com/300x150"
                            alt="Listing image"
                        )

                        .card-body.d-flex.flex-column
                            h5.card-title #{listing.title}

                            p.card-text.mb-2
                                strong Description:
                                |  #{listing.description || "No description available."}

                            p.mb-1
                                strong Exchange Type:
                                |  #{listing.exchange_type}

                            p.mb-1
                                strong Condition:
                                |  #{listing.condition_status}

                            p.mb-1
                                strong Available:
                                if listing.is_available
                                    span.badge.text-bg-success.ms-1 Yes
                                else
                                    span.badge.text-bg-danger.ms-1 No

                            .mt-auto.pt-3
                                a.btn.btn-dark.w-100(href=`/listing-detail/${listing.listing_id}`) View Details



