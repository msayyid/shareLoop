extends layout

block content
    style.
        .detail-img {
            border-radius: 24px;
            object-fit: cover;
            width: 100%;
            height: 500px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }
        .action-card {
            border-radius: 24px;
            border: 1px solid #f1f5f9;
            position: sticky;
            top: 100px;
        }
        .condition-pill {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 15px;
        }
        .related-card {
            border-radius: 20px;
            transition: transform 0.2s ease;
        }
        .related-card:hover {
            transform: translateY(-5px);
        }
        .user-avatar-placeholder {
            width: 40px;
            height: 40px;
            background: #0f172a;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

    .container.mt-5.mb-5
        //- Back Navigation
        nav.mb-4
            a.text-muted.text-decoration-none.small.fw-bold(href="/all-listings-formatted")
                i.bi.bi-arrow-left.me-2
                | BACK TO EXPLORE

        .row.g-5
            //- LEFT COLUMN: MEDIA & INFO
            .col-lg-7
                img.detail-img.mb-4(src=listing.image_path alt=listing.title)
                
                .d-flex.justify-content-between.align-items-center.mb-3
                    h2.fw-bold.mb-0 #{listing.title}
                    span.badge.rounded-pill.bg-light.text-dark.border.px-3.py-2 #{listing.category_name}

                .mt-4
                    h5.fw-bold Description
                    p.text-muted.lh-lg #{listing.description || "The owner hasn't provided a detailed description yet."}
                
                hr.my-4.opacity-25

                .mt-4
                    h5.fw-bold.mb-3 Condition Details
                    .condition-pill
                        .row
                            .col-6
                                small.text-uppercase.text-muted.fw-bold.ls-sm Quality
                                p.mb-0.fw-bold #{listing.condition_status || "Standard"}
                            .col-6
                                small.text-uppercase.text-muted.fw-bold.ls-sm Notes
                                p.mb-0 #{listing.condition_notes || "No extra notes."}

            //- RIGHT COLUMN: ACTION SIDEBAR
            .col-lg-5
                .card.action-card.shadow-sm.p-4
                    //- Seller Info
                    .d-flex.align-items-center.gap-3.mb-4
                        .user-avatar-placeholder #{listing.first_name.charAt(0)}
                        div
                            small.text-muted Shared by
                            h6.mb-0.fw-bold 
                                a.text-dark.text-decoration-none(href=`/single-user/${listing.user_id}`) #{listing.first_name}
                    
                    .mb-4
                        .d-flex.justify-content-between.mb-2
                            span.text-muted Exchange Type
                            span.fw-bold.text-primary #{listing.exchange_type.toUpperCase()}
                        .d-flex.justify-content-between
                            span.text-muted Status
                            if listing.is_available
                                span.text-success.fw-bold ● Available
                            else
                                span.text-danger.fw-bold ● Unavailable

                    //- Buttons
                    .d-grid.gap-2
                        if listing.user_id === uId
                            .alert.alert-secondary.small.text-center.rounded-3 This is your listing
                            a.btn.btn-dark.btn-lg.rounded-pill.fw-bold(href=`/listings/${listing.listing_id}/edit`) 
                                i.bi.bi-pencil.me-2
                                | Edit Listing
                        
                        else
                            if !listing.is_available
                                button.btn.btn-secondary.btn-lg.rounded-pill.disabled Item Not Available
                            
                            else if hasRequested
                                button.btn.btn-warning.btn-lg.rounded-pill.disabled.fw-bold
                                    i.bi.bi-check-circle-fill.me-2
                                    | Request Sent
                            
                            else
                                if loggedIn
                                    form(action=`/listings/${listing.listing_id}/request` method="POST")
                                        button.btn.btn-success.btn-lg.w-100.rounded-pill.fw-bold(type="submit") Request This Item
                                else
                                    a.btn.btn-success.btn-lg.rounded-pill.fw-bold(href="/login") Request This Item

                                //- Ask Question Button
                                if loggedIn
                                    a.btn.btn-outline-dark.rounded-pill.fw-bold(href=`/requests/${listing.listing_id}/start-chat`) Ask a Question
                                else
                                    a.btn.btn-outline-dark.rounded-pill.fw-bold(href="/login") Ask a Question

                    p.text-center.text-muted.small.mt-4
                        | Posted on #{listing.formatted_created_at}

        //- RELATED SECTION
        if relatedListings && relatedListings.length > 0
            .mt-5.pt-5
                h4.fw-bold.mb-4 You might also like
                .row.g-4
                    each item in relatedListings
                        .col-md-6.col-lg-4
                            .card.related-card.h-100.border-0.shadow-sm
                                .position-relative
                                    img.card-img-top(src=item.image_path style="height:220px; object-fit:cover; border-radius: 20px 20px 0 0;")
                                    span.badge.bg-white.text-dark.position-absolute.bottom-0.start-0.m-3.shadow-sm #{item.exchange_type}
                                
                                .card-body
                                    h6.fw-bold.mb-1
                                        a.text-dark.text-decoration-none(href=`/listing-detail/${item.listing_id}`) #{item.title}
                                    a.btn.btn-link.text-dark.p-0.small.fw-bold.text-decoration-none(href=`/listing-detail/${item.listing_id}`)
                                        | View Details 
                                        i.bi.bi-chevron-right.small




