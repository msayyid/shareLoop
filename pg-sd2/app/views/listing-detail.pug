extends layout

block content
    .container.mt-4

        // ===== BACK BUTTON (GLOBAL - FIXES ALIGNMENT) =====
        .mb-3
            a.btn.btn-outline-dark.btn-sm(
                href="/all-listings-formatted"
            ) ← Back to listings

        // ===== MAIN SECTION =====
        .row.g-5.align-items-start

            // ===== LEFT =====
            .col-lg-6

                // IMAGE
                img.w-100.rounded.shadow-sm(
                    src=listing.image_path
                    style="height:420px; object-fit:cover;"
                )

                // DESCRIPTION UNDER IMAGE
                .mt-4
                    h5.mb-2 Description
                    p.text-muted #{listing.description || "No description provided."}

            // ===== RIGHT =====
            .col-lg-6

                h2.fw-bold.mb-2 #{listing.title}

                // OWNER
                p.text-muted.mb-2
                    | by 
                    a.text-decoration-none.text-dark(
                        href=`/single-user/${listing.user_id}`
                    ) #{listing.first_name}

                // BADGES (BIGGER)
                .d-flex.gap-2.mb-3.flex-wrap
                    span.badge.fs-6.bg-secondary #{listing.category_name}
                    span.badge.fs-6.bg-info #{listing.exchange_type}

                    if listing.is_available
                        span.badge.fs-6.bg-success Available
                    else
                        span.badge.fs-6.bg-secondary Unavailable

                // CONDITION
                .card.bg-light.border-0.mb-3
                    .card-body
                        h6.text-muted.mb-2 Condition
                        p.mb-1
                            strong Status:
                            |  #{listing.condition_status || "Unknown"}
                        p.mb-0
                            strong Notes:
                            |  #{listing.condition_notes || "None"}

                // DATES
                p.text-muted.small.mb-4
                    | Created: #{listing.formatted_created_at} • Updated: #{listing.formatted_updated_at}

                // ===== ACTIONS =====
                .card.border-0.shadow-sm.mt-4
                    .card-body.d-flex.flex-column.gap-2

                        if listing.user_id === uId
                            span.text-muted This is your listing
                            a.btn.btn-outline-dark.w-100(
                                href=`/listings/${listing.listing_id}/edit`
                            ) Edit Listing

                        else
                            if loggedIn
                                a.btn.btn-outline-primary.w-100(
                                    href=`/requests/${listing.listing_id}/start-chat`
                                ) Ask Question
                            else
                                a.btn.btn-outline-primary.w-100(href="/login") Ask Question

                            if !listing.is_available
                                span.text-danger Item not available

                            else if hasRequested
                                span.text-warning You already requested this item

                            else
                                if loggedIn
                                    form(
                                        action=`/listings/${listing.listing_id}/request`
                                        method="POST"
                                    )
                                        button.btn.btn-success.w-100(type="submit") Request Item
                                else
                                    a.btn.btn-success.w-100(href="/login") Request Item


        // ===== RELATED SECTION =====
        if relatedListings && relatedListings.length > 0
            .mt-5.pt-4.border-top

                .d-flex.justify-content-between.align-items-center.mb-3
                    h5.mb-0 More from this category

                .row.g-4
                    each item in relatedListings
                        .col-md-6.col-lg-4
                            .card.listing-card.h-100.border-0.shadow-sm

                                .position-relative
                                    img.card-img-top(
                                        src=item.image_path
                                        style="height:200px; object-fit:cover;"
                                    )
                                    .listing-overlay

                                .card-body.d-flex.flex-column
                                    h6.card-title
                                        a.text-decoration-none.text-dark(
                                            href=`/listing-detail/${item.listing_id}`
                                        ) #{item.title}

                                    p.text-muted.small.mb-2 #{item.exchange_type}

                                    .mt-auto
                                        a.btn.btn-outline-dark.btn-sm.w-100(
                                            href=`/listing-detail/${item.listing_id}`
                                        ) View




