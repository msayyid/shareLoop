extends layout

block content
    .row.justify-content-center
        .col-lg-8
            .card.shadow-sm.border-0
                img.card-img-top(
                    src=listing.image_path
                    alt="Listing image"
                    style="object-fit:cover;"
                )

                .card-body
                    h1.card-title.mb-2= listing.title
                    p.text-muted.mb-4 View full details for this community listing

                    .d-flex.flex-wrap.gap-2.mb-3
                        span.badge.text-bg-secondary= listing.category_name
                        span.badge.text-bg-info= listing.exchange_type
                        if listing.is_available
                            span.badge.text-bg-success Available
                        else
                            span.badge.text-bg-danger Not Available

                    p.text-muted.mb-1
                        strong Owner:
                        |  
                        if listing.user_id
                            a.link-dark.text-decoration-none(href=`/single-user/${listing.user_id}`) #{listing.first_name}
                        else
                            | #{listing.first_name}

                    h5.mb-2.mt-4 Description
                    p.mb-4= listing.description || "No description available."

                    .row.g-3
                        .col-md-6
                            .card.h-100.bg-light
                                .card-body
                                    h6.card-subtitle.mb-3.text-muted Condition
                                    p.mb-2
                                        strong Status:
                                        |  #{listing.condition_status || "Unknown"}
                                    p.mb-0
                                        strong Notes:
                                        |  #{listing.condition_notes || "None"}

                        .col-md-6
                            .card.h-100.bg-light
                                .card-body
                                    h6.card-subtitle.mb-3.text-muted Dates
                                    p.mb-2
                                        strong Created:
                                        |  #{listing.formatted_created_at || "Unknown"}
                                    p.mb-0
                                        strong Updated:
                                        |  #{listing.formatted_updated_at || "Unknown"}

                .card-footer.bg-white.border-0.pt-0.pb-4.px-4
                    .d-flex.flex-wrap.gap-2
                        a.btn.btn-dark(href="/all-listings-formatted") Back to Listings
                        if listing.category_id
                            a.btn.btn-outline-secondary(href=`/all-categories/${listing.category_id}`) More in this Category

                        form(
                            action=`/listings/${listing.listing_id}/request`
                            method="POST"
                        )
                            button.btn.btn-success(type="submit") Request Item

