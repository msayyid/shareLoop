extends layout

block content
    .container.py-4
        if listings.length > 0
            h1.mb-3 Listings for tag "#{listings[0].tag_name}"
        else
            h1.mb-3 No listings found

        if tags && tags.length > 0
            .card.shadow-sm.border-0.mb-4
                .card-body
                    h5.card-title.mb-3 Filter by Tags
                    .d-flex.flex-wrap.gap-2
                        each tag in tags
                            if currentTagId == tag.tag_id
                                a.btn.btn-dark.btn-sm(href=`/tags/${tag.tag_id}`) #{tag.tag_name}
                            else
                                a.btn.btn-outline-secondary.btn-sm(href=`/tags/${tag.tag_id}`) #{tag.tag_name}

        .row.g-4
            each listing in listings
                .col-md-6.col-lg-4
                    .card.h-100.shadow-sm.border-0
                        img.card-img-top(
                            src="https://via.placeholder.com/300x150"
                            alt="Listing image"
                        )

                        .card-body.d-flex.flex-column
                            h5.card-title
                                a.text-decoration-none.text-dark(href=`/listing-detail/${listing.listing_id}`) #{listing.title}

                            p.text-muted.mb-2
                                strong Category:
                                |  #{listing.category_name}

                            p.card-text.mb-2
                                strong Description:
                                |  #{listing.description}

                            p.mb-1
                                strong Exchange Type:
                                |  #{listing.exchange_type}

                            p.mb-1
                                strong Condition:
                                |  #{listing.condition_status}

                            p.mb-1
                                strong Available:
                                if listing.is_available
                                    span.badge.text-bg-success.ms-1 Yes
                                else
                                    span.badge.text-bg-danger.ms-1 No

                            p.text-muted.small.mt-2.mb-0
                                strong Created:
                                |  #{listing.created_at.toLocaleDateString("en-GB", {day:"numeric", month:"short", year:"numeric"})}

                            .mt-auto.pt-3
                                a.btn.btn-dark.w-100(href=`/listing-detail/${listing.listing_id}`) View Details



