extends layout

block content
    .container.mt-4

        // ===== PROFILE HEADER =====
        .text-center.mb-5
            img.rounded-circle.shadow-sm.mb-3(
                src=user.profile_image_path
                width="140"
                height="140"
                style="object-fit:cover;"
            )

            h2.mb-1 #{user.first_name} #{user.last_name}

            // ⭐ Rating
            if ratingData && ratingData.total_ratings > 0
                p.mb-1(style="color:#ffc107; font-size:1.2rem;")
                    - const full = Math.floor(ratingData.avg_rating)
                    - const empty = 5 - full
                    | #{'★'.repeat(full)}#{'☆'.repeat(empty)}

                p.text-muted.small.mb-1
                    | #{ratingData.avg_rating.toFixed(1)} (#{ratingData.total_ratings} reviews)
            else
                p.text-muted.small.mb-1 No ratings yet

            p.text-muted.small.mb-0
                | Joined #{user.created_at.toLocaleDateString("en-GB", {day:"numeric", month:"short", year:"numeric"})}

        // ===== INFO + BIO (MERGED) =====
        .row.g-4.mb-5

            .col-md-6
                .card.border-0.shadow-sm.h-100
                    .card-body
                        h6.text-muted.mb-3 Basic Info

                        p.mb-2
                            strong Email:
                            |  #{user.email}

                        p.mb-2
                            strong Location:
                            |  #{user.location || "Unknown"}

                        p.mb-0
                            strong Points:
                            |  #{user.points || 0}

            .col-md-6
                .card.border-0.shadow-sm.h-100
                    .card-body
                        h6.text-muted.mb-3 Bio

                        if user.bio
                            p.text-muted.mb-0 #{user.bio}
                        else
                            p.text-muted.mb-0 No bio available.

        // ===== LISTINGS =====
        .mb-5
            h5.mb-3 Listings (#{listings.length})

            if listings.length > 0
                .row.g-4
                    each listing, index in listings
                        if index < 6
                            .col-md-6.col-lg-4
                                .card.listing-card.h-100.border-0.shadow-sm

                                    img.card-img-top(
                                        src=listing.image_path
                                        style="height:180px; object-fit:cover;"
                                    )

                                    .card-body.d-flex.flex-column
                                        h6.card-title
                                            a.text-decoration-none.text-dark(
                                                href=`/listing-detail/${listing.listing_id}`
                                            ) #{listing.title}

                                        p.text-muted.small.mb-2 #{listing.exchange_type || "Unknown"}

                                        .mt-auto
                                            a.btn.btn-outline-dark.btn-sm.w-100(
                                                href=`/listing-detail/${listing.listing_id}`
                                            ) View

                if listings.length > 6
                    .text-center.mt-3
                        a.btn.btn-outline-dark(
                            href=`/all-listings-formatted?user=${user.user_id}`
                        ) View All Listings
            else
                p.text-muted This user has no listings yet.

        // ===== REVIEWS =====
        .mb-5
            h5.mb-3 Reviews (#{reviews.length})

            if reviews.length > 0
                .list-group

                    each review in reviews
                        .list-group-item

                            .d-flex.justify-content-between.align-items-center
                                strong #{review.first_name}
                                span.text-muted.small #{new Date(review.created_at).toLocaleDateString()}

                            p.text-muted.small.mb-1
                                | For: "#{review.title}"

                            - const stars = "★".repeat(review.score) + "☆".repeat(5 - review.score)
                            p.mb-1(style="color:#ffc107;") #{stars}

                            if review.comment
                                p.mb-0 #{review.comment}
                            else
                                p.text-muted.mb-0 No comment
            else
                p.text-muted No reviews yet.

        // ===== BACK =====
        .text-center
            a.btn.btn-dark(href="/all-users-formatted") Back to Users


