extends layout

block content
    .row.justify-content-center
        .col-lg-10
            .card.shadow-sm.border-0

                .card-body.p-4

                    // Avatar + Name
                    .text-center.mb-4
                        img.rounded-circle.mb-3.shadow-sm(
                            src=user.image_path
                            alt="User avatar"
                            width="200"
                            height="200"
                            style="object-fit: cover;"
                        )

                        h1.card-title.mb-1 #{user.first_name} #{user.last_name}

                        if user.is_active
                            span.badge.bg-success.mb-2 Active
                        else
                            span.badge.bg-secondary.mb-2 Inactive

                        p.text-muted.mb-0 Community member on ShareLoop

                    // Info Cards
                    .row.g-3.mt-2

                        // Basic Info
                        .col-md-6
                            .card.h-100.bg-light
                                .card-body
                                    h6.card-subtitle.mb-3.text-muted Basic Information
                                    p.mb-2
                                        strong User ID:
                                        |  #{user.user_id}
                                    p.mb-2
                                        strong Email:
                                        |  #{user.email}
                                    p.mb-0
                                        strong Location:
                                        |  #{user.location || "Unknown"}

                        // Stats
                        .col-md-6
                            .card.h-100.bg-light
                                .card-body
                                    h6.card-subtitle.mb-3.text-muted Community Stats
                                    p.mb-2
                                        strong Points:
                                        |  #{user.points || 0}
                                    p.mb-2
                                        strong Rating:
                                        if ratingData && ratingData.total_ratings > 0 && ratingData.avg_rating
                                            |  #{ratingData.avg_rating.toFixed(1)} ⭐ (#{ratingData.total_ratings} reviews)
                                        else
                                            |  No ratings yet
                                    p.mb-2
                                        strong Lent:
                                        |  #{user.items_lent || 0}
                                    p.mb-2
                                        strong Borrowed:
                                        |  #{user.items_borrowed || 0}
                                    p.mb-0
                                        strong Given Away:
                                        |  #{user.items_given || 0}

                    // Bio
                    .mt-4
                        h5.mb-2 Bio
                        p.mb-0 #{user.bio || "No bio available."}

                    // Listings Section (BIG upgrade)
                    .mt-5
                        h5.mb-3 Listings (#{listings.length})

                        if listings.length > 0
                            .row.g-3
                                each listing in listings
                                    .col-md-6.col-lg-4
                                        .card.h-100.shadow-sm.border-0
                                            img.card-img-top(
                                                src=listing.image_path
                                                alt="Listing image"
                                                style="height:150px; object-fit:cover;"
                                            )

                                            .card-body.d-flex.flex-column
                                                h6.card-title
                                                    a.text-decoration-none.text-dark(
                                                        href=`/listing-detail/${listing.listing_id}`
                                                    ) #{listing.title}

                                                p.text-muted.mb-0 #{listing.exchange_type || "Unknown"}
                        else
                            p.text-muted This user has no listings yet.

                // ===== REVIEWS =====
                .mt-5
                    h5.mb-3 Reviews (#{reviews.length})

                    if reviews.length > 0
                        .list-group
                            each review in reviews
                                .list-group-item

                                    // TOP ROW
                                    .d-flex.justify-content-between.align-items-center
                                        strong #{review.first_name}
                                        span.text-muted #{new Date(review.created_at).toLocaleDateString()}

                                    // LISTING CONTEXT
                                    p.text-muted.mb-1
                                        | For: "#{review.title}"

                                    // STARS
                                    - const stars = "★".repeat(review.score) + "☆".repeat(5 - review.score)
                                    p.mb-1(style="color:#ffc107; font-size:1.1rem;") #{stars}

                                    // COMMENT
                                    if review.comment
                                        p.mb-0 #{review.comment}
                                    else
                                        p.text-muted.mb-0 No comment
                    else
                        p.text-muted No reviews yet.

                // Footer
                .card-footer.bg-white.border-0.pt-0.pb-4.px-4
                    .d-flex.flex-wrap.gap-2.justify-content-between
                        a.btn.btn-dark(href="/all-users-formatted") Back to Users
                        a.btn.btn-outline-primary(href="#") Message User




