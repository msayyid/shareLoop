extends layout

block content
    .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-2
        div
            h1.mb-1 Categories
            p.text-muted.mb-0 Explore items by category

    .row.g-4
        each category in categories
            .col-md-6.col-lg-4
                .card.h-100.shadow-sm.border-0.text-center
                    .card-body.d-flex.flex-column
                        .display-5.mb-3
                            if category.category_name == "Books"
                                | 📚
                            else if category.category_name == "Electronics"
                                | 💻
                            else if category.category_name == "Sports"
                                | ⚽
                            else
                                | 📦

                        h4.card-title.mb-2 #{category.category_name}

                        if category.description
                            p.card-text.text-muted.mb-3 #{category.description}

                        p.text-muted.small.mb-3 #{category.listing_count} listings

                        .mt-auto
                            a.btn.btn-dark.w-100(href=`/all-categories/${category.category_id}`) View Category

