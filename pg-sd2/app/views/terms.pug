extends layout

block content
    .container.mt-5

        .row.justify-content-center
            .col-lg-9

                .card.border-0.shadow-lg
                    .card-body.p-5

                        h2.mb-4 Terms & Conditions

                        p.text-muted
                            | By using ShareLoop, you agree to the following terms.

                        hr

                        h5.mt-4 Usage
                        p.text-muted
                            | You must provide accurate information and are responsible for your activity on the platform.

                        h5.mt-4 User Responsibilities
                        p.text-muted
                            | Users are responsible for their listings, requests, and interactions with others.

                        h5.mt-4 Prohibited Activities
                        ul.text-muted
                            li Fraudulent or misleading listings
                            li Harassment or abusive behavior
                            li Any illegal activity

                        h5.mt-4 Platform Role
                        p.text-muted
                            | ShareLoop acts as a platform and is not responsible for transactions between users.

                        h5.mt-4 Updates
                        p.text-muted
                            | These terms may be updated at any time. Continued use of the platform means you accept the changes.

                        p.text-muted.small.mt-4
                            | Last updated: #{new Date().getFullYear()}