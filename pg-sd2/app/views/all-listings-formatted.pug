extends layout

block content
    style.
        .listing-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border-radius: 16px;
            overflow: hidden;
        }
        .listing-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }
        .img-wrapper {
            position: relative;
            overflow: hidden;
        }
        .img-wrapper img {
            transition: transform 0.5s ease;
        }
        .listing-card:hover .img-wrapper img {
            transform: scale(1.05);
        }
        .filter-card {
            border-radius: 16px;
            background: #ffffff;
        }
        .badge-type {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 5px 10px;
            border-radius: 6px;
        }
        .pagination .page-link {
            border: none;
            color: #475569;
            margin: 0 3px;
            border-radius: 8px;
        }
        .pagination .active .page-link {
            background-color: #0f172a;
            color: white;
        }

    .container.mt-2
        //- ===== HEADER =====
        .text-center.mb-5
            span.badge.bg-primary.bg-opacity-10.text-primary.px-3.py-2.rounded-pill.mb-3.small.fw-bold Marketplace
            h2.fw-bold.mb-2 Community Listings
            p.text-muted Discover unique items shared by your neighbors

        //- ===== FILTER BAR =====
        .card.filter-card.border-0.shadow-sm.mb-5
            .card-body.p-4
                form(method="GET")
                    .row.g-3.align-items-end
                        .col-lg-3.col-md-6
                            label.form-label.fw-semibold.small Search
                            .input-group.input-group-sm
                                span.input-group-text.bg-light.border-end-0: i 🔍
                                input.form-control.bg-light.border-start-0(
                                    type="text"
                                    name="search"
                                    value=filters.search || ""
                                    placeholder="Search listings..."
                                )

                        .col-lg-2.col-md-3
                            label.form-label.fw-semibold.small Exchange
                            select.form-select.form-select-sm.bg-light(name="exchange")
                                option(value="") All Types
                                option(value="lending" selected=filters.exchange==="lending") Lending
                                option(value="swap" selected=filters.exchange==="swap") Swap
                                option(value="giveaway" selected=filters.exchange==="giveaway") Giveaway

                        .col-lg-2.col-md-3
                            label.form-label.fw-semibold.small Condition
                            select.form-select.form-select-sm.bg-light(name="condition")
                                option(value="") Any Condition
                                option(value="like_new" selected=filters.condition==="like_new") Like New
                                option(value="good" selected=filters.condition==="good") Good
                                option(value="fair" selected=filters.condition==="fair") Fair

                        .col-lg-2.col-md-6
                            label.form-label.fw-semibold.small Sort By
                            select.form-select.form-select-sm.bg-light(name="sort")
                                option(value="newest" selected=filters.sort==="newest") Newest First
                                option(value="popular" selected=filters.sort==="popular") Most Popular

                        .col-lg-3.col-md-6.d-flex.gap-2
                            button.btn.btn-dark.btn-sm.flex-grow-1.fw-bold(type="submit") Apply Filters
                            a.btn.btn-outline-secondary.btn-sm.px-3(href="/all-listings-formatted") 🔄

        //- ===== LISTINGS GRID =====
        if listings.length > 0
            .row.g-4
                each listing in listings
                    .col-md-6.col-lg-4
                        .card.listing-card.h-100.border-0.shadow-sm
                            //- Image Area
                            .img-wrapper
                                img.card-img-top(
                                    src=listing.image_path
                                    style="height:240px; object-fit:cover;"
                                    alt=listing.title
                                )
                                //- Status Overlay
                                .position-absolute.top-0.end-0.m-3
                                    if listing.is_available
                                        span.badge.bg-success.shadow-sm.px-3 Available
                                    else
                                        span.badge.bg-secondary.shadow-sm.px-3 Taken

                                //- Exchange Type Tag (Bottom Left of Image)
                                .position-absolute.bottom-0.start-0.m-3
                                    span.badge.bg-white.text-dark.shadow-sm.badge-type
                                        | #{listing.exchange_type}

                            .card-body.p-4.d-flex.flex-column
                                .d-flex.justify-content-between.align-items-start.mb-2
                                    h5.card-title.fw-bold.mb-0
                                        a.text-decoration-none.text-dark(href=`/listing-detail/${listing.listing_id}`) 
                                            | #{listing.title}
                                
                                p.text-muted.small.mb-3
                                    span.me-2 👤 #{listing.first_name}
                                    if listing.total_ratings > 0
                                        span.text-warning.fw-bold ⭐ #{parseFloat(listing.avg_rating).toFixed(1)} 
                                        span.text-muted (#{listing.total_ratings})
                                    else
                                        span.text-muted.small No reviews yet

                                .d-flex.align-items-center.gap-2.mb-4
                                    span.badge.bg-light.text-secondary.border.small #{listing.condition_status}
                                    span.text-muted.small •
                                    span.text-muted.small community-shared

                                .mt-auto
                                    a.btn.btn-outline-dark.w-100.rounded-pill.fw-bold(href=`/listing-detail/${listing.listing_id}`) 
                                        | View Details

        else
            .text-center.py-5
                .display-1.text-muted.opacity-25.mb-3 📦
                h4.fw-bold No listings match your search
                p.text-muted Try clearing your filters or searching for something else.
                a.btn.btn-dark.mt-2(href="/all-listings-formatted") Clear All Filters

        //- ===== PAGINATION =====
        if totalPages > 1
            nav.mt-5.py-4
                ul.pagination.justify-content-center
                    if currentPage > 1
                        li.page-item
                            a.page-link.shadow-sm(href=`?page=${currentPage - 1}`) 
                                span Prev
                    
                    each pageNum in [...Array(totalPages).keys()].map(n => n + 1)
                        li.page-item(class=pageNum === currentPage ? "active" : "")
                            a.page-link.shadow-sm(href=`?page=${pageNum}`) #{pageNum}

                    if currentPage < totalPages
                        li.page-item
                            a.page-link.shadow-sm(href=`?page=${currentPage + 1}`) 
                                span Next




