extends layout

block content
    .container.mt-4

        // ===== HEADER =====
        .text-center.mb-5
            h2.fw-bold.mb-2 All Listings
            p.text-muted.mb-0 Discover items shared by the community

        // ===== FILTER BAR (clean + compact) =====
        .card.border-0.shadow-sm.mb-4
            .card-body
                form(method="GET")
                    .row.g-3.align-items-end

                        .col-md-3
                            label.form-label.small.text-muted Search
                            input.form-control.form-control-sm(
                                type="text"
                                name="search"
                                value=filters.search || ""
                                placeholder="Search listings..."
                            )

                        .col-md-2
                            label.form-label.small.text-muted Exchange
                            select.form-select.form-select-sm(name="exchange")
                                option(value="") All
                                option(value="lending" selected=filters.exchange==="lending") Lending
                                option(value="swap" selected=filters.exchange==="swap") Swap
                                option(value="giveaway" selected=filters.exchange==="giveaway") Giveaway

                        .col-md-2
                            label.form-label.small.text-muted Condition
                            select.form-select.form-select-sm(name="condition")
                                option(value="") All
                                option(value="like_new" selected=filters.condition==="like_new") Like New
                                option(value="good" selected=filters.condition==="good") Good
                                option(value="fair" selected=filters.condition==="fair") Fair
                                option(value="well_used" selected=filters.condition==="well_used") Well Used

                        .col-md-2
                            label.form-label.small.text-muted Sort
                            select.form-select.form-select-sm(name="sort")
                                option(value="newest" selected=filters.sort==="newest") Newest
                                option(value="popular" selected=filters.sort==="popular") Popular

                        .col-md-2
                            label.form-label.small.text-muted Availability
                            select.form-select.form-select-sm(name="available")
                                option(value="") All
                                option(value="1" selected=filters.available==="1") Available

                        .col-md-2.d-flex.align-items-end.gap-2
                            button.btn.btn-dark.btn-sm.flex-fill(type="submit") Apply
                            a.btn.btn-dark.btn-sm.flex-fill.opacity-75(
                                href="/all-listings-formatted"
                            ) Reset

        // ===== LISTINGS GRID =====
        if listings.length > 0
            .row.g-4
                each listing in listings
                    .col-md-6.col-lg-4
                        .card.listing-card.h-100.border-0.shadow-sm

                            // IMAGE WRAPPER
                            .position-relative

                                img.card-img-top(
                                    src=listing.image_path
                                    style="height:230px; object-fit:cover;"
                                )

                                // GRADIENT OVERLAY
                                .listing-overlay

                                // STATUS BADGE (TOP RIGHT)
                                if listing.is_available
                                    span.badge.bg-success.position-absolute.top-0.end-0.m-2 Available
                                else
                                    span.badge.bg-dark.position-absolute.top-0.end-0.m-2 Unavailable

                            .card-body.d-flex.flex-column

                                // TITLE
                                h6.card-title.mb-1
                                    a.text-decoration-none.text-dark(
                                        href=`/listing-detail/${listing.listing_id}`
                                    ) #{listing.title}

                                // OWNER
                                p.text-muted.small.mb-1
                                    | by #{listing.first_name}

                                // RATING
                                if listing.total_ratings > 0
                                    p.text-muted.small.mb-2
                                        | ⭐ #{parseFloat(listing.avg_rating).toFixed(1)} (#{listing.total_ratings})
                                else
                                    p.text-muted.small.mb-2 No ratings

                                // META
                                p.text-muted.small.mb-2
                                    | #{listing.exchange_type} • #{listing.condition_status}

                                .mt-auto
                                    a.btn.btn-outline-dark.btn-sm.w-100(
                                        href=`/listing-detail/${listing.listing_id}`
                                    ) View

        else
            .text-center.mt-5
                h5.text-muted No listings found
                p.text-muted.small Try adjusting filters

        // ===== PAGINATION =====
        if totalPages > 1
            nav.mt-5
                ul.pagination.justify-content-center.pagination-sm

                    if currentPage > 1
                        li.page-item
                            a.page-link(href=`?page=${currentPage - 1}`) ←

                    each pageNum in [...Array(totalPages).keys()].map(n => n + 1)
                        li.page-item(class=pageNum === currentPage ? "active" : "")
                            a.page-link(href=`?page=${pageNum}`) #{pageNum}

                    if currentPage < totalPages
                        li.page-item
                            a.page-link(href=`?page=${currentPage + 1}`) →

