        //- ===== MAIN NAVIGATION =====
        nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.sticky-top.py-3
            .container
                //- 1. Brand (Always Visible)
                a.navbar-brand.d-flex.align-items-center(href="/")
                    span.me-2 🔄
                    | ShareLoop

                //- 2. RIGHT-SIDE ACTIONS (Always Visible outside the collapse)
                .d-flex.align-items-center.ms-auto.order-lg-3
                    if loggedIn
                        //- Messages
                        a.nav-link.text-white.px-2.position-relative(href="/my-chats")
                            | 💬
                        
                        //- Notifications Dropdown
                        .dropdown.px-2
                            a.nav-link.dropdown-toggle.hide-caret.text-white(
                                href="#"
                                role="button"
                                data-bs-toggle="dropdown"
                            )
                                span.notification-bell.position-relative
                                    | 🔔
                                    if unreadCount > 0
                                        span.position-absolute.top-0.start-100.translate-middle.badge.rounded-pill.bg-danger.notification-badge
                                            | #{unreadCount}

                            ul.dropdown-menu.dropdown-menu-end.notifications-dropdown.shadow-lg(style="width: 280px; position: absolute;")
                                li.dropdown-header.text-uppercase.fw-bold.small Notifications
                                if notifications.length === 0
                                    li: span.dropdown-item.text-muted.small No new alerts
                                else
                                    each n in notifications
                                        li: a.dropdown-item.small(href=`/notifications/${n.notification_id}/read` class=n.is_read ? "" : "fw-bold")
                                            | #{n.message}

                        //- User Profile
                        .dropdown.ms-2
                            a.nav-link.dropdown-toggle.d-flex.align-items-center(
                                href="#"
                                role="button"
                                data-bs-toggle="dropdown"
                            )
                                if currentUser && currentUser.profile_image_path
                                    img.border.border-1.border-secondary(
                                        src=currentUser.profile_image_path
                                        style="width:32px; height:32px; object-fit:cover; border-radius:50%;"
                                    )
                                else
                                    .bg-secondary.rounded-circle.d-flex.align-items-center.justify-content-center(style="width:32px; height:32px;")
                                        span.text-white.small(style="font-size: 0.7rem;") 👤

                            ul.dropdown-menu.dropdown-menu-end.shadow-lg
                                li: a.dropdown-item(href="/profile") My Profile
                                li: a.dropdown-item(href="/dashboard") Dashboard
                                li: hr.dropdown-divider
                                li: a.dropdown-item.text-danger(href="/logout") Logout
                    else
                        a.nav-link.text-white.small.me-2(href="/login") Login
                        a.btn.btn-light.btn-sm.fw-bold(href="/register") Join

                //- 3. The Toggle Button (Visible only on mobile)
                button.navbar-toggler.border-0.ms-2(
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav"
                )
                    span.navbar-toggler-icon

                //- 4. The Collapsible Links (Home, Listings, etc.)
                #mainNav.collapse.navbar-collapse.order-lg-2
                    ul.navbar-nav.mx-auto
                        li.nav-item: a.nav-link.px-3(href="/") Home
                        li.nav-item: a.nav-link.px-3(href="/all-listings-formatted") Listings
                        li.nav-item: a.nav-link.px-3(href="/all-users-formatted") Neighbors
                        li.nav-item: a.nav-link.px-3(href="/about") About

        //- ===== SECONDARY CATEGORY BAR =====
        if !hideCategories && categories && categories.length
            .bg-white.shadow-sm.py-2
                .container
                    .d-flex.align-items-center.overflow-auto.py-1(style="white-space: nowrap; -ms-overflow-style: none; scrollbar-width: none;")
                        span.text-muted.small.fw-bold.me-3.text-uppercase Categories:
                        .d-flex.gap-2
                            each category in categories
                                a.category-pill(href=`/all-categories/${category.category_id}`) #{category.category_name}

        //- ===== MAIN CONTENT =====
        main.container.py-5.flex-grow-1
            block content

        //- ===== FOOTER =====
        footer.mt-auto.py-4(style="background-color: #0f172a;")
            .container
                .row.gy-3.align-items-start
                    //- LEFT COLUMN: Brand & Description
                    .col-md-5.col-lg-4.text-center.text-md-start
                        h5.text-white.fw-bold.mb-2 ShareLoop
                        p.mb-0(style="color: #cbd5e1; font-size: 0.85rem; line-height: 1.5;")
                            | Building stronger communities through the power of sharing. Reduce waste, meet neighbors, and save money.
                    
                    //- MIDDLE COLUMN: Links 1
                    .col-6.col-md-3.col-lg-2.offset-lg-2.text-center.text-md-start
                        h6.text-white.fw-bold.mb-2.small.text-uppercase(style="letter-spacing: 1px;") Platform
                        ul.list-unstyled.mb-0
                            li: a.footer-link.small(href="/all-listings-formatted") Browse Items
                            li: a.footer-link.small(href="/all-users-formatted") Neighbors
                            li: a.footer-link.small(href="/about") Our Mission
                    
                    //- RIGHT COLUMN: Links 2
                    .col-6.col-md-3.col-lg-2.text-center.text-md-start
                        h6.text-white.fw-bold.mb-2.small.text-uppercase(style="letter-spacing: 1px;") Support
                        ul.list-unstyled.mb-0
                            li: a.footer-link.small(href="/contact") Contact Us
                            li: a.footer-link.small(href="/privacy") Privacy Policy
                            li: a.footer-link.small(href="/terms") Terms of Service

                //- Thin line with less margin
                hr.my-3(style="border-top: 1px solid rgba(255,255,255,0.1);")
                
                //- BOTTOM ROW: Copyright
                .row.align-items-center
                    .col-md-6.text-center.text-md-start
                        p.mb-0.small(style="color: #94a3b8;") © #{new Date().getFullYear()} ShareLoop Inc. All rights reserved.
                    .col-md-6.text-center.text-md-end.mt-2.mt-md-0
                        span.small(style="color: #cbd5e1; font-weight: 500;") Made with ❤️ for the Planet

        //- Scripts (Bootstrap & Custom)
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
        script.
            const isLoggedIn = document.body.dataset.loggedIn === "true";

            if (isLoggedIn) {
                async function refreshNotifications() {
                    try {
                        const res = await fetch("/api/notifications");
                        if (!res.ok) return;
                        const data = await res.json();
                        
                        const badge = document.querySelector(".notification-badge");
                        const bellContainer = document.querySelector(".notification-bell");
                        const dropdown = document.querySelector(".notifications-dropdown");

                        // Update Badge
                        if (data.unreadCount > 0) {
                            if (!badge && bellContainer) {
                                const newBadge = document.createElement("span");
                                newBadge.className = "position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge";
                                newBadge.textContent = data.unreadCount;
                                bellContainer.appendChild(newBadge);
                            } else if (badge) {
                                badge.textContent = data.unreadCount;
                            }
                        } else if (badge) badge.remove();

                        // Update Dropdown List
                        if (dropdown) {
                            const header = '<li class="dropdown-header text-uppercase fw-bold small">Notifications</li>';
                            if (data.notifications.length === 0) {
                                dropdown.innerHTML = header + '<li><span class="dropdown-item text-muted small">No new alerts</span></li>';
                            } else {
                                const items = data.notifications.map(n => `
                                    <li>
                                        <a class="dropdown-item small ${n.is_read ? '' : 'fw-bold'}" href="/notifications/${n.notification_id}/read">
                                            ${n.message}
                                        </a>
                                    </li>
                                `).join('');
                                dropdown.innerHTML = header + items;
                            }
                        }
                    } catch (err) { console.error("Notification Sync Error", err); }
                }
                setInterval(refreshNotifications, 10000); // Polling every 10s for performance
            }


