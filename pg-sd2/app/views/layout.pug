doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1")
        title #{title || "ShareLoop | Community Sharing"}

        //- Google Fonts for a more modern feel
        link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet")
        
        link(
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
        )
        
        style.
            body { font-family: 'Inter', sans-serif; color: #1e293b; }
            .navbar { border-bottom: 1px solid rgba(255,255,255,0.1); }
            .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }
            
            /* Category Pills */
            .category-pill {
                display: inline-block;
                padding: 6px 16px;
                border-radius: 50px;
                background: #f1f5f9;
                color: #475569;
                text-decoration: none;
                font-size: 0.85rem;
                font-weight: 500;
                transition: all 0.2s ease;
                border: 1px solid transparent;
            }
            .category-pill:hover {
                background: #e2e8f0;
                color: #0f172a;
                transform: translateY(-1px);
            }

            /* Notifications & Dropdowns */
            .notification-bell { font-size: 1.2rem; cursor: pointer; }
            .notification-badge { font-size: 0.6rem; padding: 4px 6px; }
            .dropdown-menu { border: none; shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border-radius: 12px; padding: 0.75rem; }
            .dropdown-item { border-radius: 8px; padding: 8px 12px; transition: background 0.2s; }
            
            /* Footer Styling */
            footer { background-color: #0f172a !important; }
            footer a { text-decoration: none; transition: color 0.2s; color: #94a3b8 !important; }
            footer a:hover { color: #f8f9fa !important; }

        link(rel="stylesheet", href="/css/style.css")

