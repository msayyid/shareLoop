doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1")
        title #{title || "ShareLoop"}

        link(
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        )

        link(rel="stylesheet", href="/css/style.css")

    body.bg-light(data-logged-in=loggedIn ? "true" : "false")
        // MAIN NAVBAR (ROW 1)
        nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
            .container
                a.navbar-brand(href="/") ShareLoop

                button.navbar-toggler(
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav"
                    aria-controls="mainNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation"
                )
                    span.navbar-toggler-icon

                #mainNav.collapse.navbar-collapse
                    ul.navbar-nav.ms-auto
                        li.nav-item
                            a.nav-link(href="/") Home
                        li.nav-item
                            a.nav-link(href="/all-users-formatted") Users
                        li.nav-item
                            a.nav-link(href="/all-listings-formatted") Listings

                        if loggedIn
                            //- li.nav-item
                            //-     a.nav-link(href="/dashboard") Dashboard

                            li.nav-item
                                a.nav-link.fw-bold(href="/my-chats") My Chats

                            // USER AVATAR DROPDOWN
                            li.nav-item.dropdown
                                a.nav-link.dropdown-toggle(
                                    href="#"
                                    role="button"
                                    data-bs-toggle="dropdown"
                                )
                                    if currentUser && currentUser.profile_image_path
                                        img(
                                            src=currentUser.profile_image_path
                                            style="width:32px; height:32px; object-fit:cover; border-radius:50%;"
                                        )

                                ul.dropdown-menu.dropdown-menu-end
                                    li
                                        a.dropdown-item(href="/profile") Profile
                                    li
                                        a.dropdown-item(href="/dashboard") Dashboard
                                    li
                                        hr.dropdown-divider
                                    li
                                        a.dropdown-item(href="/logout") Logout

                            // Notifications
                            li.nav-item.dropdown
                                a.nav-link.dropdown-toggle(
                                    href="#"
                                    role="button"
                                    data-bs-toggle="dropdown"
                                )
                                    span.position-relative.notification-bell
                                        | 🔔
                                        if unreadCount > 0
                                            span.position-absolute.top-0.start-100.translate-middle.badge.rounded-pill.bg-danger.notification-badge
                                                | #{unreadCount}

                                ul.dropdown-menu.dropdown-menu-end.notifications-dropdown
                                    if notifications.length === 0
                                        li
                                            span.dropdown-item.text-muted No notifications
                                    else
                                        each n in notifications
                                            li
                                                a.dropdown-item(
                                                    href=`/notifications/${n.notification_id}/read`
                                                    class=n.is_read ? "" : "fw-bold"
                                                )
                                                    | #{n.message}

                            //- li.nav-item
                            //-     a.nav-link(href="/logout") Logout

                        else
                            li.nav-item
                                a.nav-link(href="/login") Login
                            li.nav-item
                                a.nav-link(href="/register") Register

        // CATEGORY BAR (ROW 2)
        if !hideCategories && categories && categories.length
            .bg-white.border-bottom
                .container.py-2
                    .d-flex.flex-wrap.justify-content-center.gap-2
                        each category in categories
                            a.category-pill(
                                href=`/all-categories/${category.category_id}`
                            ) #{category.category_name}

        main.container.py-4
            block content

        script.
            const isLoggedIn = document.body.dataset.loggedIn === "true";

            document.addEventListener("DOMContentLoaded", () => {
                if (!isLoggedIn) return;

                async function refreshNotifications() {
                    try {
                        const res = await fetch("/api/notifications");
                        if (!res.ok) return;

                        const data = await res.json();

                        // ===== BADGE =====
                        let badge = document.querySelector(".notification-badge");
                        const bellContainer = document.querySelector(".notification-bell");

                        if (data.unreadCount > 0) {
                            if (!badge && bellContainer) {
                                badge = document.createElement("span");
                                badge.className = "position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge";
                                bellContainer.appendChild(badge);
                            }

                            if (badge) {
                                badge.textContent = data.unreadCount;
                            }
                        } else {
                            if (badge) {
                                badge.remove();
                            }
                        }

                        // ===== DROPDOWN =====
                        const dropdown = document.querySelector(".notifications-dropdown");

                        if (dropdown) {
                            dropdown.innerHTML = "";

                            if (data.notifications.length === 0) {
                                dropdown.innerHTML = `
                                    <li>
                                        <span class="dropdown-item text-muted">
                                            No notifications
                                        </span>
                                    </li>
                                `;
                            } else {
                                data.notifications.forEach(n => {
                                    const item = document.createElement("li");

                                    item.innerHTML = `
                                        <a class="dropdown-item ${n.is_read ? "" : "fw-bold"}"
                                        href="/notifications/${n.notification_id}/read">
                                            ${n.message}
                                        </a>
                                    `;

                                    dropdown.appendChild(item);
                                });
                            }
                        }

                    } catch (err) {
                        console.error("notif error", err);
                    }
                }

                // 🔥 IMPORTANT: run immediately + poll
                refreshNotifications();
                setInterval(refreshNotifications, 1000);
            });

        script(
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        )

