extends layout

block content
    .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-2
        div
            h1.mb-1 Community Members
            p.text-muted.mb-0 Meet the people sharing items on ShareLoop

    .row.g-4
        each user in results
            .col-md-6.col-lg-4
                .card.h-100.shadow-sm.border-0
                    .card-body.d-flex.flex-column.text-center
                        .mb-3
                            img.rounded-circle.mx-auto.d-block.shadow-sm(
                                src=user.profile_image_path
                                alt="User avatar"
                                width="100"
                                height="100"
                                style="object-fit: cover;"
                            )

                        h5.card-title.mb-2 #{user.first_name} #{user.last_name}

                        if user.bio
                            p.card-text.text-muted.mb-3 #{user.bio}
                        else
                            p.card-text.text-muted.mb-3 No bio available.

                        p.mb-1
                            strong Location:
                            |  #{user.location || "Unknown"}

                        p.mb-1
                            strong Rating:
                            |  #{user.average_rating || "N/A"}

                        p.mb-1
                            strong Points:
                            |  #{user.points || 0}

                        p.text-muted.small.mt-2.mb-0
                            strong Joined:
                            |  #{user.created_at.toLocaleDateString("en-GB", {day:"numeric", month:"short", year:"numeric"})}

                        .mt-auto.pt-3
                            a.btn.btn-dark.w-100(href=`/single-user/${user.user_id}`) View Profile


