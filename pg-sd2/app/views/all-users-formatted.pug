extends layout

block content
    style.
        .user-card {
            transition: all 0.3s ease;
            border-radius: 20px;
            overflow: visible; /* Allows the 'Top' badge to pop out */
        }
        .user-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.08) !important;
        }
        .avatar-container {
            width: 100px;
            height: 100px;
            margin: -50px auto 15px auto; /* Pulls avatar up slightly for a 'profile' look */
            position: relative;
        }
        .avatar-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: 4px solid #ffffff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .points-badge {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 4px 12px;
            border-radius: 50px;
            font-weight: 600;
            color: #475569;
        }
        .filter-section {
            background: #ffffff;
            border-radius: 16px;
        }

    .container.mt-5
        //- ===== HEADER =====
        .text-center.mb-5
            span.badge.bg-info.bg-opacity-10.text-info.px-3.py-2.rounded-pill.mb-3.small.fw-bold Directory
            h2.fw-bold.mb-1 Community Members
            p.text-muted Meet the neighbors who make ShareLoop possible

        //- ===== FILTERS =====
        .card.filter-section.border-0.shadow-sm.mb-5
            .card-body.p-4
                form(method="GET")
                    .row.g-3.align-items-end
                        .col-md-4
                            label.form-label.fw-semibold.small Search
                            input.form-control.form-control-sm.bg-light.border-0(
                                type="text"
                                name="search"
                                value=(filters && filters.search) || ""
                                placeholder="Name or bio..."
                            )

                        .col-md-3
                            label.form-label.fw-semibold.small Sort
                            select.form-select.form-select-sm.bg-light.border-0(name="sort")
                                option(value="newest" selected=(filters && filters.sort==="newest")) Newest Joiners
                                option(value="rating" selected=(filters && filters.sort==="rating")) Top Rated
                                option(value="points" selected=(filters && filters.sort==="points")) Most Active

                        .col-md-3
                            label.form-label.fw-semibold.small Filter
                            select.form-select.form-select-sm.bg-light.border-0(name="hasRating")
                                option(value="") All Members
                                option(value="1" selected=(filters && filters.hasRating==="1")) Rated Members Only

                        .col-md-2.d-flex.gap-2
                            button.btn.btn-dark.btn-sm.flex-fill.fw-bold(type="submit") Apply
                            a.btn.btn-outline-secondary.btn-sm.px-3(href="/all-users-formatted") 🔄

        //- ===== USERS GRID =====
        .row.g-5.mt-2
            each user in results
                .col-md-6.col-lg-4
                    .card.user-card.border-0.shadow-sm.pt-5
                        .card-body.text-center.d-flex.flex-column.pt-0
                            //- AVATAR
                            .avatar-container
                                img.rounded-circle.avatar-img(
                                    src=user.profile_image_path || '/images/default-avatar.png'
                                )
                                if user.points >= 200
                                    span.badge.bg-warning.text-dark.position-absolute.top-0.end-0.rounded-pill.shadow-sm(title="Top Contributor")
                                        | ⭐

                            //- NAME & LOCATION
                            h5.fw-bold.mb-1 #{user.first_name} #{user.last_name}
                            p.text-muted.small.mb-3 
                                i.me-1 📍
                                | #{user.location || "Neighbor"}

                            //- RATING
                            .mb-3
                                if user.total_ratings > 0 && user.avg_rating
                                    - const fullStars = Math.floor(user.avg_rating)
                                    span.text-warning.me-1 #{'★'.repeat(fullStars)}#{'☆'.repeat(5 - fullStars)}
                                    span.small.fw-bold.text-dark #{user.avg_rating.toFixed(1)}
                                    span.text-muted.small  (#{user.total_ratings})
                                else
                                    span.text-muted.small No ratings yet

                            //- BIO
                            if user.bio
                                p.text-muted.small.mb-4.px-3(style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px;") 
                                    | "#{user.bio}"
                            else
                                p.text-muted.small.mb-4.fst-italic Just joined the community!

                            //- POINTS & FOOTER
                            .d-flex.justify-content-center.align-items-center.mb-4
                                span.points-badge.small
                                    | 🪙 #{user.points} points

                            .mt-auto
                                a.btn.btn-outline-dark.w-100.rounded-pill.fw-bold.btn-sm(
                                    href=`/single-user/${user.user_id}`
                                ) View Profile

        //- ===== EMPTY STATE =====
        if results.length === 0
            .text-center.py-5
                .display-1.text-muted.opacity-25.mb-3 👥
                h4.fw-bold No neighbors found
                p.text-muted Try a different name or clearing the filters.

        //- ===== PAGINATION =====
        if totalPages > 1
            nav.mt-5.py-4
                ul.pagination.justify-content-center.gap-1
                    if currentPage > 1
                        li.page-item: a.page-link.rounded-pill.shadow-sm(href=`?page=${currentPage - 1}`) Prev
                    
                    each pageNum in [...Array(totalPages).keys()].map(n => n + 1)
                        li.page-item(class=pageNum === currentPage ? "active" : "")
                            a.page-link.rounded-pill.shadow-sm(href=`?page=${pageNum}`) #{pageNum}

                    if currentPage < totalPages
                        li.page-item: a.page-link.rounded-pill.shadow-sm(href=`?page=${currentPage + 1}`) Next





