extends layout

block content
    .container.mt-5

        // HERO
        .text-center.mb-5
            h1.fw-bold ShareLoop
            p.lead.text-muted Share More. Waste Less. Connect Better.

        // MAIN CARD
        .row.justify-content-center
            .col-lg-9

                .card.border-0.shadow-lg
                    .card-body.p-5

                        h4.mb-3 Our Mission
                        p.text-muted ShareLoop exists to make sharing simple. Instead of buying more, we help people lend, borrow, and exchange items within their community.

                        hr.my-4

                        .row.g-4
                            .col-md-6
                                h5 The Problem
                                p.text-muted Many people own items they rarely use, while others need those same items. This leads to unnecessary spending and waste.

                            .col-md-6
                                h5 Our Solution
                                p.text-muted ShareLoop connects people so they can share resources instead of owning everything individually.

                        hr.my-4

                        h5.mb-3 What You Can Do
                        .row.g-3

                            .col-md-4
                                .p-3.border.rounded.text-center
                                    h6.mb-1 📦 List Items
                                    small.text-muted Share items you no longer use

                            .col-md-4
                                .p-3.border.rounded.text-center
                                    h6.mb-1 🔄 Request & Swap
                                    small.text-muted Borrow or exchange items easily

                            .col-md-4
                                .p-3.border.rounded.text-center
                                    h6.mb-1 ⭐ Build Trust
                                    small.text-muted Ratings and reviews ensure safety

                        hr.my-4

                        h5 Our Vision
                        p.text-muted.mb-0 We believe in a world where access matters more than ownership. ShareLoop aims to build communities where resources are shared, not wasted.

                        .text-center.mt-4
                            a.btn.btn-dark(href="/register") Join ShareLoop