extends layout

block content
    style.
        .chat-tile {
            border-radius: 16px;
            transition: all 0.2s ease;
            border: 1px solid #f1f5f9 !important;
            margin-bottom: 12px;
        }
        .chat-tile:hover {
            background-color: #f8fafc;
            transform: translateX(5px);
        }
        .unread-dot {
            width: 10px;
            height: 10px;
            background-color: #3b82f6;
            border-radius: 50%;
            display: inline-block;
        }
        .avatar-overlap {
            position: relative;
            width: 60px;
            height: 60px;
        }
        .listing-img-sm {
            border-radius: 12px;
            object-fit: cover;
            border: 2px solid white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

    .container.mt-5.mb-5
        .d-flex.justify-content-between.align-items-center.mb-4
            div
                h2.fw-bold.mb-1 Messages
                p.text-muted.small Coordinate your shares and swaps.
            span.badge.bg-dark.rounded-pill.px-3 #{chats.length} Chats

        if chats.length === 0
            .card.border-0.shadow-sm.rounded-4.text-center.p-5
                .mb-3(style="font-size: 3rem;") 💬
                h5.fw-bold No conversations yet
                p.text-muted Start a conversation by requesting an item or responding to a request.
        else
            .row.justify-content-center
                .col-lg-10
                    .list-group.list-group-flush
                        each chat in chats
                            a.list-group-item.list-group-item-action.chat-tile.p-3.d-flex.align-items-center.gap-3(
                                href=`/requests/${chat.request_id}/messages`
                            )
                                //- IMAGE SECTION
                                .avatar-overlap
                                    img.listing-img-sm(
                                        src=chat.image_path || "/images/listings/default-listing-pic.jpg"
                                        width="60"
                                        height="60"
                                    )
                                
                                //- CONTENT SECTION
                                .flex-grow-1.min-width-0
                                    .d-flex.justify-content-between.align-items-center.mb-1
                                        h6.fw-bold.mb-0.text-truncate #{chat.title}
                                        small.text-muted #{chat.last_message_time ? new Date(chat.last_message_time).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) : ''}
                                    
                                    .d-flex.justify-content-between.align-items-center
                                        div.text-truncate
                                            span.text-dark.fw-semibold.small #{chat.first_name}: 
                                            span(class=chat.unread_count > 0 ? "fw-bold text-dark" : "text-muted small")
                                                | #{chat.last_message || "Start the conversation..."}
                                        
                                        if chat.unread_count > 0
                                            span.badge.rounded-pill.bg-primary #{chat.unread_count}
                                        else
                                            i.bi.bi-chevron-right.text-light.small





