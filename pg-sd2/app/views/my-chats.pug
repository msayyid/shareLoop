extends layout

block content
    .container.mt-4

        h4.mb-4 My Conversations

        if chats.length === 0
            .alert.alert-light.border
                p.mb-0 You have no conversations yet.

        else
            .list-group.shadow-sm

                each chat in chats
                    a.list-group-item.list-group-item-action.d-flex.align-items-center.gap-3(
                        href=`/requests/${chat.request_id}/messages`
                    )

                        // ===== IMAGE (listing) =====
                        if chat.image_path
                            img.rounded(
                                src=chat.image_path
                                width="60"
                                height="60"
                                style="object-fit:cover;"
                            )
                        else
                            img.rounded(
                                src="/images/listings/default-listing-pic.jpg"
                                width="60"
                                height="60"
                            )

                        // ===== CONTENT =====
                        .flex-grow-1

                            .d-flex.justify-content-between.align-items-center

                                // TITLE + UNREAD BADGE
                                div
                                    strong(class=chat.unread_count > 0 ? "fw-bold" : "")
                                        | #{chat.title}

                                    if chat.unread_count > 0
                                        span.badge.bg-danger.ms-2 #{chat.unread_count}

                                // TIME
                                small.text-muted
                                    if chat.last_message_time
                                        | #{new Date(chat.last_message_time).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}

                            // USER
                            small.text-muted
                                | Chat with #{chat.first_name}

                            br

                            // LAST MESSAGE
                            if chat.last_message
                                small(
                                    class=chat.unread_count > 0 ? "fw-bold" : "text-muted"
                                ).text-truncate
                                    | #{chat.last_message}
                            else
                                small.text-muted Start conversation

                        // ===== STATUS =====
                        span.badge.bg-light.text-dark Open