extends layout

block content
    .container.mt-4
        .card.shadow-sm
            .card-body

                // PROFILE IMAGE
                if user.profile_image_path
                    img(
                        src=user.profile_image_path
                        style="width:120px; height:120px; object-fit:cover; border-radius:50%; margin-bottom:15px;"
                    )

                h3.mb-3 Profile

                p
                    strong Name:
                    |  #{user.first_name} #{user.last_name}

                p
                    strong Email:
                    |  #{user.email}

                p
                    strong Bio:
                    |  #{user.bio || "No bio"}

                p
                    strong Location:
                    |  #{user.location || "Not set"}

                hr

                a.btn.btn-dark(href="/profile/edit") Edit Profile