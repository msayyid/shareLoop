extends layout

block content
    .container.mt-5
        .row.justify-content-center
            .col-lg-6.col-md-8

                .card.border-0.shadow-sm

                    .card-body.text-center

                        // ===== AVATAR =====
                        img.rounded-circle.shadow-sm.mb-3(
                            src=user.profile_image_path
                            width="120"
                            height="120"
                            style="object-fit:cover;"
                        )

                        // ===== NAME + EMAIL =====
                        h4.mb-1 #{user.first_name} #{user.last_name}
                        p.text-muted.small.mb-1 #{user.email}

                        p.text-muted.small.mb-3
                            | Member since #{user.created_at.toLocaleDateString("en-GB", {day:"numeric", month:"short", year:"numeric"})}

                        hr

                        // ===== DETAILS =====
                        .text-start.mt-3

                            p.mb-2
                                strong Location:
                                |  #{user.location || "Not set"}

                            p.mb-2
                                strong Bio:
                                if user.bio
                                    span.text-muted  #{user.bio}
                                else
                                    span.text-muted  No bio yet

                        // ===== ACTION =====
                        .mt-4
                            a.btn.btn-dark.w-100(href="/profile/edit") Edit Profile