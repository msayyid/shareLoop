extends layout

block content
    .container

        .row.justify-content-center
            .col-lg-8

                // HEADER
                .d-flex.justify-content-between.align-items-center.mb-3
                    h5.mb-0 #{listing.title}
                    a.btn.btn-outline-dark.btn-sm(href="/my-chats") Back

                // CHAT BOX
                .card.shadow-sm

                    .card-body#chat-box(
                        style="height:450px; overflow-y:auto; background:#f8f9fa;"
                    )

                // INPUT
                form.mt-3(method="POST")
                    .input-group
                        input.form-control(
                            type="text"
                            name="message"
                            placeholder="Type a message..."
                            required
                        )
                        button.btn.btn-dark(type="submit") Send

        script.
            const requestId = !{request.request_id};
            const uId = !{uId};
            let lastMessageId = 0;

            const chatBox = document.getElementById("chat-box");

            function scrollToBottom() {
                chatBox.scrollTop = chatBox.scrollHeight;
            }

            let lastSenderId = null;

            function renderMessage(msg) {
                const isMe = msg.sender_id == uId;

                const wrapper = document.createElement("div");
                wrapper.className = "mb-2 d-flex flex-column " + (isMe ? "align-items-end" : "align-items-start");

                // show name only when sender changes
                if (msg.sender_id !== lastSenderId) {
                    const name = document.createElement("small");
                    name.style.fontSize = "0.7rem";
                    name.style.opacity = "0.6";
                    name.textContent = isMe ? "You" : msg.first_name;
                    wrapper.appendChild(name);
                }

                const bubble = document.createElement("div");
                bubble.style.maxWidth = "65%";
                bubble.style.padding = "10px";
                bubble.style.borderRadius = "12px";
                bubble.style.marginTop = "2px";
                bubble.style.backgroundColor = isMe ? "#0d6efd" : "#e9ecef";
                bubble.style.color = isMe ? "white" : "black";

                bubble.innerHTML = `
                    <div>${msg.message}</div>
                    <div style="font-size:10px; opacity:0.6; text-align:right;">
                        ${new Date(msg.created_at).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}
                    </div>
                `;

                wrapper.appendChild(bubble);
                chatBox.appendChild(wrapper);

                lastSenderId = msg.sender_id;
            }

            async function loadMessages() {
                const res = await fetch(`/api/requests/${requestId}/messages`);
                const messages = await res.json();

                chatBox.innerHTML = "";
                chatBox.innerHTML = "";
                lastSenderId = null;
                messages.forEach(renderMessage);

                scrollToBottom();
            }

            loadMessages();
            setInterval(loadMessages, 3000);