extends layout

block content
    .container.mt-4

        // ===== USER INFO =====
        .row.mb-4
            .col-md-8
                h2 Hi, #{user.first_name} 👋
                p.text-muted #{user.bio}
                p
                    strong Email:
                    |  #{user.email}

            .col-md-4.text-end.d-flex.justify-content-end.gap-2
                a.btn.btn-outline-dark(href="/my-requests") My Requests
                a.btn.btn-dark(href="/listings/new") + Create Listing

        hr

        // ===== MY LISTINGS =====
        h3.mb-3 My Listings

        if listings.length === 0
            .alert.alert-light.border
                p.mb-0 You don’t have any listings yet.
                a(href="/listings/new") Create your first listing

        else
            .row.g-4
                each listing in listings
                    .col-md-6.col-lg-4
                        .card.h-100.shadow-sm

                            // IMAGE
                            img.card-img-top(src=listing.image_path, alt="listing image")

                            .card-body.d-flex.flex-column

                                // TITLE
                                h5.card-title #{listing.title}

                                // DESCRIPTION (short)
                                p.card-text.text-muted #{listing.description}

                                // DETAILS
                                p.mb-1
                                    strong Type:
                                    |  #{listing.exchange_type}

                                p.mb-2
                                    strong Status:
                                    if listing.is_available
                                        span.text-success Available
                                    else
                                        span.text-danger Unavailable

                                // BUTTONS
                                .div.mt-auto.d-flex.gap-2

                                    // View button
                                    a.btn.btn-outline-dark(
                                        href=`/listing-detail/${listing.listing_id}`
                                    ) View

                                    // Delete form
                                    form(
                                        action=`/listings/${listing.listing_id}/delete`
                                        method="POST"
                                        onsubmit="return confirm('Are you sure you want to delete this listing?');"
                                    )
                                        button.btn.btn-danger(type="submit") Delete

        // ===== INCOMING REQUESTS =====
        h3.mb-3 Incoming Requests

            if requests.length === 0
                .alert.alert-light.border
                    p.mb-0 No one has requested your listings yet.

            else
                .list-group
                    each request in requests
                        .list-group-item.d-flex.justify-content-between.align-items-center

                            .d-flex.flex-column
                                strong #{request.first_name} requested "#{request.title}"
                                span.text-muted Status: #{request.status}

                            if request.status === 'pending'
                                .d-flex.gap-2
                                    form(action=`/requests/${request.request_id}/accept` method="POST")
                                        button.btn.btn-success.btn-sm(type="submit") Accept
                                    form(action=`/requests/${request.request_id}/reject` method="POST")
                                        button.btn.btn-outline-danger.btn-sm(type="submit") Reject
                                