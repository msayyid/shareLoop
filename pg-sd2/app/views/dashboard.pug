extends layout

block content
    style.
        .dashboard-header {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid #f1f5f9;
        }
        .stat-card {
            border-radius: 20px;
            transition: transform 0.2s ease;
            background: #ffffff;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin-bottom: 1rem;
        }
        .listing-manage-card {
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .listing-manage-card:hover {
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        }
        .status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
        }

    .container.mt-5.mb-5
        //- ===== HEADER SECTION =====
        .dashboard-header.p-4.shadow-sm.mb-5
            .row.align-items-center.g-3
                .col-md-auto
                    .position-relative
                        img.rounded-circle.border.border-3.border-white.shadow-sm(
                            src=user.profile_image_path || '/images/default-avatar.png'
                            width="90"
                            height="90"
                            style="object-fit:cover;"
                        )
                        span.position-absolute.bottom-0.end-0.bg-success.border.border-2.border-white.rounded-circle(style="width:18px; height:18px;")
                
                .col-md
                    h3.fw-bold.mb-1 Welcome back, #{user.first_name}!
                    p.text-muted.small.mb-0 
                        i.bi.bi-envelope.me-1
                        | #{user.email} • Member since 2026

                .col-md-auto
                    .d-flex.gap-2
                        a.btn.btn-outline-dark.rounded-pill.px-4.fw-bold.btn-sm(href="/requests/received") 📥 Incoming
                        a.btn.btn-dark.rounded-pill.px-4.fw-bold.btn-sm(href="/listings/new") + New Listing

        //- ===== ANALYTICS STATS =====
        .row.g-4.mb-5
            .col-md-4
                .card.stat-card.border-0.shadow-sm
                    .card-body.p-4
                        .stat-icon.bg-primary.bg-opacity-10.text-primary 📦
                        h3.fw-bold.mb-0 #{listings.length}
                        p.text-muted.small.mb-0 Active Listings

            .col-md-4
                .card.stat-card.border-0.shadow-sm
                    .card-body.p-4
                        .stat-icon.bg-warning.bg-opacity-10.text-warning 🔔
                        h3.fw-bold.mb-0 #{requests.length}
                        p.text-muted.small.mb-0 Open Requests

            .col-md-4
                .card.stat-card.border-0.shadow-sm
                    .card-body.p-4
                        .stat-icon.bg-success.bg-opacity-10.text-success 🪙
                        h3.fw-bold.mb-0 #{user.points || 0}
                        p.text-muted.small.mb-0 Reputation Points

        //- ===== MY LISTINGS =====
        .d-flex.justify-content-between.align-items-end.mb-4
            div
                h4.fw-bold.mb-1 My Inventory
                p.text-muted.small.mb-0 Manage the items you're sharing with the community
            
        if listings.length === 0
            .card.border-0.shadow-sm.rounded-4.text-center.p-5
                .mb-3(style="font-size: 3rem;") 📭
                h5.fw-bold Your inventory is empty
                p.text-muted Start sharing items to earn points and help neighbors.
                .mt-3
                    a.btn.btn-dark.rounded-pill.px-4(href="/listings/new") Create My First Listing
        else
            .row.g-4
                each listing in listings
                    .col-md-6.col-lg-4
                        .card.listing-manage-card.border-0.shadow-sm.h-100
                            .position-relative
                                img.card-img-top(
                                    src=listing.image_path
                                    style="height:200px; object-fit:cover;"
                                )
                                .position-absolute.top-0.end-0.m-2
                                    if listing.is_available
                                        span.badge.rounded-pill.bg-success.px-3 Available
                                    else
                                        span.badge.rounded-pill.bg-danger.px-3 In Use

                            .card-body.d-flex.flex-column
                                .d-flex.justify-content-between.align-items-start.mb-2
                                    h6.fw-bold.mb-0 #{listing.title}
                                    span.badge.bg-light.text-dark.small #{listing.exchange_type}

                                p.text-muted.small.mb-4.text-truncate-2 #{listing.description}

                                .mt-auto.pt-3.border-top.d-flex.gap-2
                                    a.btn.btn-outline-dark.btn-sm.flex-fill.rounded-pill(
                                        href=`/listing-detail/${listing.listing_id}`
                                    ) View
                                    
                                    form(
                                        action=`/listings/${listing.listing_id}/delete`
                                        method="POST"
                                        onsubmit="return confirm('Are you sure? This cannot be undone.');"
                                        style="flex:1"
                                    )
                                        button.btn.btn-outline-danger.btn-sm.w-100.rounded-pill(type="submit") Delete

        //- ===== QUICK EXPLORE =====
        .mt-5.pt-5
            .row.g-4
                .col-md-6
                    .card.border-0.shadow-sm.rounded-4.bg-dark.text-white.p-4
                        h5.fw-bold Find something to borrow?
                        p.text-secondary.small Browse what your neighbors are offering.
                        a.btn.btn-light.btn-sm.rounded-pill.px-4.fw-bold(href="/all-listings-formatted") Browse All
                
                .col-md-6
                    .card.border-0.shadow-sm.rounded-4.p-4(style="background: #e2e8f0;")
                        h5.fw-bold Track your requests
                        p.text-muted.small Check the status of items you've asked for.
                        a.btn.btn-dark.btn-sm.rounded-pill.px-4.fw-bold(href="/my-requests") View Requests





