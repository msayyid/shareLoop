extends layout

block content
    .container.mt-4

        // ===== HEADER CARD =====
        .card.border-0.shadow-sm.mb-4
            .card-body.d-flex.justify-content-between.align-items-center.flex-wrap.gap-3

                // LEFT
                .d-flex.align-items-center.gap-3
                    img.rounded-circle.shadow-sm(
                        src=user.profile_image_path
                        width="70"
                        height="70"
                        style="object-fit:cover;"
                    )

                    .d-flex.flex-column
                        h4.mb-1 Hi, #{user.first_name} 👋
                        p.text-muted.small.mb-0 #{user.email}

                // RIGHT ACTIONS
                .d-flex.gap-2.flex-wrap
                    a.btn.btn-outline-dark.btn-sm(href="/my-requests") My Requests
                    a.btn.btn-outline-dark.btn-sm(href="/requests/received") Incoming
                    a.btn.btn-dark.btn-sm(href="/listings/new") + New Listing

        // ===== QUICK STATS =====
        .row.g-3.mb-4

            .col-md-4
                .card.border-0.shadow-sm.text-center
                    .card-body
                        h5.mb-1 #{listings.length}
                        p.text-muted.small.mb-0 My Listings

            .col-md-4
                .card.border-0.shadow-sm.text-center
                    .card-body
                        h5.mb-1 #{requests.length}
                        p.text-muted.small.mb-0 Incoming Requests

            .col-md-4
                .card.border-0.shadow-sm.text-center
                    .card-body
                        h5.mb-1 #{user.points || 0}
                        p.text-muted.small.mb-0 Points

        // ===== MY LISTINGS =====
        h4.mb-3 My Listings

        if listings.length === 0
            .alert.alert-light.border
                p.mb-0 You don’t have any listings yet.
                a(href="/listings/new") Create your first listing

        else
            .row.g-4
                each listing in listings
                    .col-md-6.col-lg-4
                        .card.dashboard-card.h-100.border-0.shadow-sm

                            .position-relative
                                img.card-img-top(
                                    src=listing.image_path
                                    style="height:180px; object-fit:cover;"
                                )

                                if !listing.is_available
                                    span.badge.bg-secondary.position-absolute.top-0.end-0.m-2
                                        Unavailable

                            .card-body.d-flex.flex-column

                                h6.card-title.mb-1 #{listing.title}

                                p.text-muted.small.mb-2.text-truncate
                                    #{listing.description}

                                .d-flex.justify-content-between.small.mb-3
                                    span #{listing.exchange_type}
                                    if listing.is_available
                                        span.text-success Available
                                    else
                                        span.text-danger Unavailable

                                .mt-auto.d-flex.gap-2
                                    a.btn.btn-outline-dark.btn-sm.flex-fill(
                                        href=`/listing-detail/${listing.listing_id}`
                                    ) View

                                    form(
                                        action=`/listings/${listing.listing_id}/delete`
                                        method="POST"
                                        onsubmit="return confirm('Delete this listing?');"
                                        style="flex:1"
                                    )
                                        button.btn.btn-outline-danger.btn-sm.w-100(type="submit") Delete

        // ===== FILL SPACE (RECOMMENDED) =====
        .mt-5
            h4.mb-3 Explore More

            .row.g-3
                .col-md-4
                    .card.border-0.shadow-sm.text-center
                        .card-body
                            h6.mb-2 Browse Listings
                            p.text-muted.small.mb-3 Discover new items
                            a.btn.btn-outline-dark.btn-sm(href="/all-listings-formatted") Explore

                .col-md-4
                    .card.border-0.shadow-sm.text-center
                        .card-body
                            h6.mb-2 Find Users
                            p.text-muted.small.mb-3 Connect with community
                            a.btn.btn-outline-dark.btn-sm(href="/all-users-formatted") View Users

                .col-md-4
                    .card.border-0.shadow-sm.text-center
                        .card-body
                            h6.mb-2 Your Requests
                            p.text-muted.small.mb-3 Track your activity
                            a.btn.btn-outline-dark.btn-sm(href="/my-requests") My Requests          